<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Overlay permission (granted via Settings intent) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground service permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Notification permission (runtime on API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Auto-restart on boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Battery optimization whitelist prompt -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Exact alarm for OEM kill recovery -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Network: scoped to :net process only. Enforced by OrbitNoHttpClientOutsideNet lint rule. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- App usage stats for AppCategory detection -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Activity Recognition for StateSnapshot -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- T073: ScreenshotObserver watches the user's screenshot folder. Min SDK 33
         so only the post-API-33 flavour is required. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <queries>
        <package android:name="androidx.test.services" />
    </queries>

    <application
        android:name=".CapsuleApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Capsule">

        <!-- :ui process (default) -->
        <!-- T052/T053: DiaryActivity is the launcher entry point for User Story 2. -->
        <activity
            android:name=".diary.DiaryActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Capsule">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MainActivity demoted to deep-link-only setup/permissions screen. -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.Capsule" />

        <!-- T096: OnboardingActivity — first-run only, routed from DiaryActivity. -->
        <activity
            android:name=".onboarding.OnboardingActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.Capsule" />

        <!-- T103b: ReducedModeActivity — read-only Diary when capture perms declined. -->
        <activity
            android:name=".onboarding.ReducedModeActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.Capsule" />

        <!-- T070: SettingsActivity — deep-link only (opened from Diary). -->
        <activity
            android:name=".settings.SettingsActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.Capsule" />

        <!-- T091a: TrashActivity — opened from Settings. -->
        <activity
            android:name=".settings.TrashActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:parentActivityName=".settings.SettingsActivity"
            android:theme="@style/Theme.Capsule" />

        <!-- T091: AuditLogActivity — "What Orbit did today". -->
        <activity
            android:name=".audit.AuditLogActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:parentActivityName=".settings.SettingsActivity"
            android:theme="@style/Theme.Capsule" />

        <!-- T055b: EnvelopeDetailActivity — launched from EnvelopeCard tap.
             Not exported; internal explicit-intent only. -->
        <activity
            android:name=".diary.EnvelopeDetailActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:parentActivityName=".diary.DiaryActivity"
            android:theme="@style/Theme.Capsule" />

        <!-- :capture process -->
        <service
            android:name=".service.CapsuleOverlayService"
            android:process=":capture"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Persistent user-interactive floating overlay for explicit clipboard capture triggered by user tap. Requires continuous foreground presence to render TYPE_APPLICATION_OVERLAY window." />
        </service>

        <!-- :ml process — encrypted Room DB owner, AI inference -->
        <service
            android:name=".data.ipc.EnvelopeRepositoryService"
            android:process=":ml"
            android:exported="false">
            <intent-filter>
                <action android:name="com.capsule.app.action.BIND_ENVELOPE_REPOSITORY" />
                <action android:name="com.capsule.app.action.BIND_AUDIT_LOG" />
            </intent-filter>
        </service>

        <!-- :net process — sole network egress -->
        <service
            android:name=".net.NetworkGatewayService"
            android:process=":net"
            android:exported="false">
            <intent-filter>
                <action android:name="com.capsule.app.action.BIND_NETWORK_GATEWAY" />
            </intent-filter>
        </service>

        <!-- 003 v1.1: ActionExecutorService runs in :capture (no-network process).
             Bound by :ui via "com.capsule.app.action.BIND_ACTION_EXECUTOR".
             See specs/003-orbit-actions/contracts/action-execution-contract.md §2.
             No new permissions are added by 003 — see T099. -->
        <service
            android:name=".action.ActionExecutorService"
            android:process=":capture"
            android:exported="false">
            <intent-filter>
                <action android:name="com.capsule.app.action.BIND_ACTION_EXECUTOR" />
            </intent-filter>
        </service>

        <!-- 003 v1.1: ActionsSettingsActivity — deep-link only (opened from Settings → Actions). -->
        <activity
            android:name=".settings.ActionsSettingsActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:parentActivityName=".settings.SettingsActivity"
            android:theme="@style/Theme.Capsule" />

        <receiver
            android:name=".service.RestartReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>